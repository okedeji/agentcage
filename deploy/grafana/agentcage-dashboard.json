{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for agentcage OTel metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "agentcage Overview",
  "uid": "agentcage-overview",
  "tags": ["agentcage"],
  "timezone": "utc",
  "refresh": "10s",
  "panels": [
    {
      "title": "Active Cages",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "agentcage_cage_active_count", "legendFormat": "active"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
    },
    {
      "title": "Fleet Capacity Utilization",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "agentcage_fleet_capacity_utilization_ratio", "legendFormat": "utilization"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]}}}
    },
    {
      "title": "Fleet Hosts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "agentcage_fleet_hosts_active", "legendFormat": "hosts"}]
    },
    {
      "title": "Pending Interventions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "agentcage_intervention_timeout_total", "legendFormat": "timed out"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },
    {
      "title": "Cage Startup Duration (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.99, rate(agentcage_cage_startup_duration_seconds_bucket[5m]))", "legendFormat": "p99"}],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"thresholdsStyle": {"mode": "line"}}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "Cage Teardown Duration (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.99, rate(agentcage_cage_teardown_duration_seconds_bucket[5m]))", "legendFormat": "p99"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Egress Blocked (rate/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "targets": [{"expr": "rate(agentcage_enforcement_egress_blocked_total[5m]) * 60", "legendFormat": "blocked/min"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "title": "Payload Blocked (rate/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "targets": [{"expr": "rate(agentcage_enforcement_payload_blocked_total[5m]) * 60", "legendFormat": "blocked/min"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "orange"}}}
    },
    {
      "title": "Findings Processed (rate/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "targets": [
        {"expr": "rate(agentcage_findings_processed_total{type=\"candidate\"}[5m]) * 60", "legendFormat": "candidate"},
        {"expr": "rate(agentcage_findings_processed_total{type=\"validated\"}[5m]) * 60", "legendFormat": "validated"},
        {"expr": "rate(agentcage_findings_processed_total{type=\"rejected\"}[5m]) * 60", "legendFormat": "rejected"}
      ]
    },
    {
      "title": "LLM Tokens Consumed (rate/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{"expr": "rate(agentcage_gateway_tokens_consumed_total[5m]) * 60", "legendFormat": "{{provider}} / {{model}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "LLM Request Duration (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "histogram_quantile(0.99, rate(agentcage_gateway_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Intervention Response Time (p90)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [{"expr": "histogram_quantile(0.90, rate(agentcage_intervention_response_duration_seconds_bucket[5m]))", "legendFormat": "p90"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 600}]}}}
    },
    {
      "title": "Intervention Timeouts (total)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [{"expr": "increase(agentcage_intervention_timeout_total[1h])", "legendFormat": "timeouts/hour"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    }
  ]
}
