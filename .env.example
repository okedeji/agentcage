# agentcage environment variables
#
# Copy to .env and fill in the values you need. All variables are
# optional; agentcage uses sensible defaults when they are unset.

# ---------------------
# Paths
# ---------------------

# Base directory for all agentcage data (embedded services, bundles,
# logs, PID files). Default: ~/.agentcage
# AGENTCAGE_HOME=/opt/agentcage

# Path to the operator config YAML. Default: searches
# $AGENTCAGE_HOME/config.yaml, ~/.agentcage/config.yaml,
# /etc/agentcage/config.yaml in order.
# AGENTCAGE_CONFIG=/etc/agentcage/config.yaml

# ---------------------
# gRPC client (used by agentcage run, status, etc.)
# ---------------------

# Address of the orchestrator gRPC server.
# Default: localhost:9090
# AGENTCAGE_GRPC_ADDR=orchestrator.internal:9090

# Client TLS certificate and key for mTLS to the orchestrator.
# Omit all three for plaintext (fine for localhost/dev).
# AGENTCAGE_TLS_CERT=/etc/agentcage/tls/client.crt
# AGENTCAGE_TLS_KEY=/etc/agentcage/tls/client.key

# CA certificate to verify the orchestrator's TLS cert.
# AGENTCAGE_TLS_CA=/etc/agentcage/tls/ca.crt

# ---------------------
# API keys
# ---------------------

# LLM provider API key (e.g. Anthropic, OpenAI).
# AGENTCAGE_LLM_API_KEY=sk-...

# Temporal Cloud API key for managed Temporal deployments.
# AGENTCAGE_TEMPORAL_API_KEY=...

# Fleet webhook provisioner API key.
# AGENTCAGE_FLEET_API_KEY=...

# ---------------------
# systemd socket activation (set by systemd, not by the operator)
# ---------------------

# LISTEN_PID and LISTEN_FDS are set automatically by systemd when
# using socket activation. Do not set these manually.
# LISTEN_PID=
# LISTEN_FDS=
