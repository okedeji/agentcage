instance_type     = "m8i.large"
spot              = false       # set true for cheapest throwaway testing
enable_ssh        = true        # auto-generates SSH key at agentcage-ssh.pem
my_ip             = "0.0.0.0/0" # restrict to your IP if static, or leave open

# LLM webhook gateway (deployed on free-tier t3.micro)
webhook_api_key    = ""          # shared secret between agentcage and the webhook (used for both /llm and /judge routes)
llm_provider_url   = "https://api.openai.com/v1/chat/completions"
llm_provider_key   = ""          # your OpenAI (or other provider) API key for LLM calls
llm_model          = "gpt-5.5"   # model the webhook uses for LLM calls
judge_provider_url = ""          # empty → reuses llm_provider_url. Set explicitly for a different judge endpoint.
judge_provider_key = ""          # empty → reuses llm_provider_key. Set explicitly for separate billing / a different provider.
judge_model        = "gpt-5.5"   # model the webhook uses for judge calls (consider a cheaper model — judge runs on every flagged request)

# spot = false: use pause/resume to save costs (~$2.40/month when stopped)
#   terraform output pause_command   -> stops instance, runs agentcage stop
#   terraform output resume_command  -> starts instance, agentcage auto-starts
#
# spot = true: cheapest while running, but cannot pause. Use terraform
#   destroy/apply to tear down and recreate.

# Config and secrets are auto-detected from local files:
#   config.yaml   -> written to /etc/agentcage/config.yaml on the instance
#   secrets.env   -> written to /etc/agentcage/secrets.env on the instance
# Place them next to this file. Both are gitignored.
