# Secrets seeded into Vault on first agentcage init.
# Both keys are the same WEBHOOK_API_KEY value from terraform.tfvars —
# the webhook auths /llm and /judge routes with one shared secret, but
# agentcage stores them under two separate Vault paths.

AGENTCAGE_LLM_API_KEY=<webhook_api_key value>
AGENTCAGE_JUDGE_API_KEY=<webhook_api_key value>

# Target credentials. The AGENTCAGE_TARGET_<KEY> prefix is recognized by
# seedSecrets — value is parsed as JSON when it starts with '{' and
# written to Vault under target/<key-lowercased-with-hyphens>. After
# seeding, run an assessment with --credentials-key <key-lowercased>
# (e.g. --credentials-key paraclete-creds) and the cage receives the
# resolved JSON in AGENTCAGE_TARGET_CREDENTIALS.
# AGENTCAGE_TARGET_PARACLETE_CREDS={"type":"header","name":"Authorization","value":"Bearer eyJ..."}
